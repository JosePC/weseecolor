---
export const prerender = true;
import BaseLayout from '~/layouts/BaseLayout.astro';
import PageHero from '~/components/PageHero.astro';
import ExpertCard from '~/components/ExpertCard.astro';
import { reader } from '~/lib/keystatic';

const allExperts = await reader.collections.experts.all();
const experts = allExperts
  .map((e) => e.entry)
  .sort((a, b) => (a.order ?? 0) - (b.order ?? 0));
---
<BaseLayout title="Meet Our Experts" description="The dermatologists, scientists, and educators guiding our evidence-based work.">
  <PageHero title="Meet Our Experts" eyebrow="Experts" lede="The dermatologists, scientists, educators, and advocates guiding our evidence-based product analysis and community work." />
  <section class="max-w-7xl mx-auto px-5 md:px-8 py-12 md:py-16">
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-x-6 gap-y-10">
      {
        experts.map((e) => (
          <ExpertCard
            name={e.name}
            href={`/${e.slug}/`}
            role={e.role}
            credentials={e.credentials}
            photo={e.photo}
          />
        ))
      }
    </div>
    {experts.length === 0 && (
      <p class="text-center text-[var(--color-ink-muted)] py-12">No experts published yet.</p>
    )}
  </section>
</BaseLayout>
