---
export const prerender = true;
import BaseLayout from '~/layouts/BaseLayout.astro';
import PageHero from '~/components/PageHero.astro';
import Prose from '~/components/Prose.astro';
import VideoGrid from '~/components/VideoGrid.astro';
import ArticleCard from '~/components/ArticleCard.astro';
import { reader } from '~/lib/keystatic';

export async function getStaticPaths() {
  const experts = await reader.collections.experts.all();
  const hubs = await reader.collections.hubs.all();
  return [
    ...experts.map((e) => ({
      params: { slug: e.entry.slug || e.slug },
      props: { kind: 'expert' as const, id: e.slug },
    })),
    ...hubs.map((h) => ({
      params: { slug: h.entry.slug || h.slug },
      props: { kind: 'hub' as const, id: h.slug },
    })),
  ];
}

type Props = { kind: 'expert' | 'hub'; id: string };
const { kind, id } = Astro.props as Props;

let expert: any = null;
let hub: any = null;
let hubVideos: any[] = [];
let hubArticles: any[] = [];

if (kind === 'expert') {
  expert = await reader.collections.experts.read(id, { resolveLinkedFiles: true });
} else {
  hub = await reader.collections.hubs.read(id, { resolveLinkedFiles: true });
  if (hub) {
    const allVideos = await reader.collections.videos.all();
    hubVideos = hub.videoRefs?.length
      ? allVideos.filter((v: any) => hub.videoRefs.includes(v.slug))
      : [];
    const allArticles = await reader.collections.articles.all();
    hubArticles = hub.articleRefs?.length
      ? allArticles.filter((a: any) => hub.articleRefs.includes(a.slug))
      : [];
  }
}

if (!expert && !hub) {
  return new Response('Not Found', { status: 404 });
}
---

{expert && (
  <BaseLayout
    title={expert.name}
    description={expert.seo?.metaDescription ?? undefined}
    ogImage={expert.photo ?? undefined}
  >
    <section class="max-w-5xl mx-auto px-5 md:px-8 py-12 md:py-16">
      <div class="grid md:grid-cols-[260px_1fr] gap-10 items-start">
        <div>
          <div class="aspect-square rounded-2xl overflow-hidden bg-[var(--color-surface-alt)]">
            {expert.photo && <img src={expert.photo} alt={expert.name} class="w-full h-full object-cover" />}
          </div>
          {expert.links?.length > 0 && (
            <div class="mt-5 space-y-2">
              {expert.links.map((l: any) => (
                <a href={l.url} target="_blank" rel="noopener noreferrer" class="block text-sm text-[var(--color-brand)] hover:underline">
                  {l.label} →
                </a>
              ))}
            </div>
          )}
        </div>
        <div>
          <h1 class="font-serif text-4xl md:text-5xl font-semibold tracking-tight">
            {expert.name}{expert.credentials ? `, ${expert.credentials}` : ''}
          </h1>
          {expert.role && <p class="mt-3 text-lg text-[var(--color-ink-muted)]">{expert.role}</p>}
          {expert.expertise?.length > 0 && (
            <ul class="mt-5 flex flex-wrap gap-2">
              {expert.expertise.map((x: string) => (
                <li class="px-3 py-1 rounded-full text-xs bg-[var(--color-pill-bg)] text-[var(--color-brand-deep)]">{x}</li>
              ))}
            </ul>
          )}
          <div class="mt-8">
            {expert.bio && <Prose document={expert.bio} />}
          </div>
          {expert.featuredVideoUrl && (
            <div class="mt-10">
              <VideoGrid videos={[{ title: `${expert.name} — Interview`, youtubeUrl: expert.featuredVideoUrl }]} columns={2} />
            </div>
          )}
        </div>
      </div>
    </section>
  </BaseLayout>
)}

{hub && (
  <BaseLayout
    title={hub.title}
    description={hub.seo?.metaDescription ?? undefined}
    ogImage={hub.heroImage ?? undefined}
  >
    <PageHero title={hub.title} image={hub.heroImage} />
    <section class="max-w-5xl mx-auto px-5 md:px-8 py-12 md:py-16 space-y-12">
      {hub.intro && <div class="max-w-3xl"><Prose document={hub.intro} /></div>}
      {hubArticles.length > 0 && (
        <div>
          <h2 class="font-serif text-2xl font-semibold mb-6">Related articles</h2>
          <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
            {hubArticles.map((a: any) => (
              <ArticleCard
                title={a.entry.title}
                href={`/informative/${a.entry.slug}/`}
                excerpt={a.entry.excerpt}
                coverImage={a.entry.coverImage}
                category={a.entry.category}
                readTime={a.entry.readTime}
              />
            ))}
          </div>
        </div>
      )}
      {hubVideos.length > 0 && (
        <div>
          <h2 class="font-serif text-2xl font-semibold mb-6">Watch &amp; learn</h2>
          <VideoGrid
            videos={hubVideos.map((v: any) => ({
              title: v.entry.title,
              youtubeUrl: v.entry.youtubeUrl,
              description: v.entry.description,
              customThumbnail: v.entry.thumbnail,
            }))}
          />
        </div>
      )}
      {hub.externalLinks?.length > 0 && (
        <div>
          <h2 class="font-serif text-2xl font-semibold mb-4">More resources</h2>
          <ul class="space-y-2">
            {hub.externalLinks.map((l: any) => (
              <li><a href={l.url} class="text-[var(--color-brand)] hover:underline">{l.label} →</a></li>
            ))}
          </ul>
        </div>
      )}
    </section>
  </BaseLayout>
)}
