---
export const prerender = true;
import BaseLayout from '~/layouts/BaseLayout.astro';
import PageHero from '~/components/PageHero.astro';
import Prose from '~/components/Prose.astro';
import TallyEmbed from '~/components/TallyEmbed.astro';
import { reader } from '~/lib/keystatic';

const page = await reader.singletons.askUsToReviewAProduct.read({ resolveLinkedFiles: true });
const settings = await reader.singletons.settings.read();
const formId = page?.tallyFormId || settings?.tallyFormIds?.productEvaluationRequest || '';
const title = page?.title ?? 'Ask Us to Review a Product';
---
<BaseLayout title={title} description={page?.seo?.metaDescription ?? undefined}>
  <PageHero title={title} />
  <section class="max-w-3xl mx-auto px-5 md:px-8 py-12 md:py-16 space-y-8">
    {page?.body && <Prose document={page.body} />}
    <div class="rounded-xl border border-[var(--color-pill-bg)] p-6 md:p-8 bg-white">
      <TallyEmbed formId={formId} minHeight={900} />
    </div>
  </section>
</BaseLayout>
