---
export const prerender = true;
import BaseLayout from '~/layouts/BaseLayout.astro';
import PageHero from '~/components/PageHero.astro';
---
<BaseLayout title="Coming to Maryland — July 2025" description="WeSeeColor telehealth services are coming to Maryland in July 2025.">
  <PageHero title="Coming to Maryland" eyebrow="Telehealth" lede="WeSeeColor telehealth services are launching in Maryland in July 2025." />
  <section class="max-w-3xl mx-auto px-5 md:px-8 py-12 md:py-16 text-center">
    <p class="text-lg text-[var(--color-ink-muted)] leading-relaxed">
      We're excited to bring evidence-based dermatology care to Maryland residents. Check back in July 2025 — or explore our resources in the meantime.
    </p>
    <div class="mt-8 flex flex-wrap justify-center gap-4">
      <a href="/telehealth/" class="inline-block px-6 py-3 bg-[var(--color-brand)] text-white font-medium rounded-full hover:bg-[var(--color-brand-deep)] transition-colors">
        Learn About Telehealth
      </a>
      <a href="/find-a-practitioner/" class="inline-block px-6 py-3 border border-[var(--color-brand)] text-[var(--color-brand)] font-medium rounded-full hover:bg-[var(--color-pill-bg)] transition-colors">
        Find a Practitioner
      </a>
    </div>
  </section>
</BaseLayout>
