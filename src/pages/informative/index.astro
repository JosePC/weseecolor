---
export const prerender = true;
import BaseLayout from '~/layouts/BaseLayout.astro';
import PageHero from '~/components/PageHero.astro';
import ArticleCard from '~/components/ArticleCard.astro';
import CategoryPill from '~/components/CategoryPill.astro';
import { reader } from '~/lib/keystatic';

const allArticles = await reader.collections.articles.all();
const articles = allArticles
  .map((a) => a.entry)
  .sort((a, b) => {
    const da = a.publishedAt ? new Date(a.publishedAt).getTime() : 0;
    const db = b.publishedAt ? new Date(b.publishedAt).getTime() : 0;
    return db - da;
  });

const categories = [...new Set(articles.map((a) => a.category).filter(Boolean))];
---
<BaseLayout title="Articles &amp; Research" description="Evidence-based skin and hair care articles from dermatologists and scientists at WeSeeColor.">
  <PageHero title="Articles &amp; Research" eyebrow="Informative" lede="Evidence-based articles from dermatologists, scientists, and health educators." />
  <section class="max-w-7xl mx-auto px-5 md:px-8 py-12 md:py-16">
    {categories.length > 1 && (
      <div class="flex flex-wrap gap-2 mb-10">
        {categories.map((cat) => (
          <CategoryPill label={cat!} />
        ))}
      </div>
    )}
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {articles.map((a) => (
        <ArticleCard
          title={a.title}
          href={`/informative/${a.slug}/`}
          excerpt={a.excerpt}
          coverImage={a.coverImage}
          category={a.category}
          readTime={a.readTime}
        />
      ))}
    </div>
    {articles.length === 0 && (
      <p class="text-center text-[var(--color-ink-muted)] py-12">No articles published yet.</p>
    )}
  </section>
</BaseLayout>
