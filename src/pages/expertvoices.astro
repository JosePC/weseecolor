---
export const prerender = true;
import BaseLayout from '~/layouts/BaseLayout.astro';
import PageHero from '~/components/PageHero.astro';
import Prose from '~/components/Prose.astro';
import VideoGrid from '~/components/VideoGrid.astro';
import { reader } from '~/lib/keystatic';

const page = await reader.singletons.expertVoices.read({ resolveLinkedFiles: true });
const title = page?.title ?? 'Expert Voices';

const allVideos = await reader.collections.videos.all();
const featured = page?.featuredVideos?.length
  ? allVideos.filter((v) => page.featuredVideos.includes(v.slug))
  : allVideos.filter((v) => v.entry.category === 'expert-voices');
---
<BaseLayout title={title} description={page?.seo?.metaDescription ?? undefined}>
  <PageHero title={title} image={page?.heroImage} />
  <section class="max-w-7xl mx-auto px-5 md:px-8 py-12 md:py-16 space-y-12">
    {page?.body && <div class="max-w-3xl"><Prose document={page.body} /></div>}
    {featured.length > 0 && (
      <VideoGrid
        videos={featured.map((v) => ({
          title: v.entry.title,
          youtubeUrl: v.entry.youtubeUrl,
          description: v.entry.description,
          customThumbnail: v.entry.thumbnail,
        }))}
      />
    )}
  </section>
</BaseLayout>
