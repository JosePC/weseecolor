---
export const prerender = true;
import BaseLayout from '~/layouts/BaseLayout.astro';
import PageHero from '~/components/PageHero.astro';
import Prose from '~/components/Prose.astro';
import { reader } from '~/lib/keystatic';

const page = await reader.singletons.care.read({ resolveLinkedFiles: true });
const title = page?.title ?? 'Care';
---
<BaseLayout title={title} description={page?.seo?.metaDescription ?? undefined}>
  <PageHero title={title} image={page?.heroImage} />
  <article class="max-w-3xl mx-auto px-5 md:px-8 py-12 md:py-16">
    {page?.body && <Prose document={page.body} />}
  </article>
</BaseLayout>
