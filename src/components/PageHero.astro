---
interface Props {
  title: string;
  image?: string | null;
  subtitle?: string;
}
const { title, image, subtitle } = Astro.props;
const bg = image || '/images/page-title-default.jpg';
---
<section class="relative h-[260px] md:h-[340px] overflow-hidden">
  <img src={bg} alt="" class="absolute inset-0 w-full h-full object-cover object-center" />
  <div class="absolute inset-0 bg-black/45"></div>
  <div class="relative z-10 h-full max-w-5xl mx-auto px-5 md:px-8 flex flex-col justify-center">
    <h1 class="font-heading text-4xl md:text-5xl font-normal text-white text-balance">{title}</h1>
    {subtitle && <p class="mt-3 text-white/90 text-lg text-balance max-w-3xl">{subtitle}</p>}
  </div>
</section>
