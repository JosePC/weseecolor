---
interface Props {
  title: string;
  eyebrow?: string;
  image?: string | null;
  lede?: string;
}
const { title, eyebrow, image, lede } = Astro.props;
---
<section class="bg-[var(--color-surface-alt)] border-b border-[var(--color-pill-bg)]">
  <div class="max-w-7xl mx-auto px-5 md:px-8 py-12 md:py-20">
    <div class="max-w-3xl">
      {eyebrow && <p class="text-sm uppercase tracking-widest text-[var(--color-brand)] font-medium mb-3">{eyebrow}</p>}
      <h1 class="font-serif text-4xl md:text-5xl font-semibold tracking-tight">{title}</h1>
      {lede && <p class="mt-4 text-lg text-[var(--color-ink-muted)] leading-relaxed">{lede}</p>}
    </div>
    {image && (
      <div class="mt-8 aspect-[21/9] rounded-2xl overflow-hidden bg-white">
        <img src={image} alt="" class="w-full h-full object-cover" />
      </div>
    )}
  </div>
</section>
