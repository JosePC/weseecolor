---
interface Source {
  label: string;
  url: string;
}
interface Props {
  sources: Source[];
}
const { sources } = Astro.props;
---
{
  sources && sources.length > 0 && (
    <aside class="mt-12 pt-8 border-t border-[var(--color-pill-bg)]">
      <h2 class="text-xs uppercase tracking-widest text-[var(--color-ink-muted)] mb-4">References</h2>
      <ol class="space-y-2 text-sm list-decimal pl-5 text-[var(--color-ink-muted)]">
        {sources.map((s) => (
          <li>
            <a href={s.url} target="_blank" rel="noopener noreferrer" class="hover:text-[var(--color-brand)] underline">
              {s.label}
            </a>
          </li>
        ))}
      </ol>
    </aside>
  )
}
