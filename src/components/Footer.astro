---
import { reader } from '~/lib/keystatic';

const footer = (await reader.singletons.footer.read()) ?? {
  columns: [
    {
      title: 'Explore',
      links: [
        { label: 'Who We Are', href: '/who/' },
        { label: 'Advocacy', href: '/advocacy/' },
        { label: 'Expert Voices', href: '/expertvoices/' },
      ],
    },
    {
      title: 'Learn',
      links: [
        { label: 'Skin & Hair Conditions', href: '/skin-and-hair-conditions/' },
        { label: 'Care', href: '/care/' },
        { label: 'Community Conversations', href: '/community-conversations/' },
      ],
    },
    {
      title: 'Act',
      links: [
        { label: 'Find a Practitioner', href: '/find-a-practitioner/' },
        { label: 'Product Reviews', href: '/product-reviews/' },
        { label: 'Join Us', href: '/join-us/' },
      ],
    },
  ],
  social: [],
  copyright: `© ${new Date().getFullYear()} WeSeeColor. All rights reserved.`,
};
---

<footer class="bg-[var(--color-surface-alt)] border-t border-[var(--color-pill-bg)] mt-16">
  <div class="max-w-7xl mx-auto px-5 md:px-8 py-12">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
      <div class="col-span-2 md:col-span-1">
        <div class="font-serif text-xl font-semibold">
          We<span class="text-[var(--color-brand)]">See</span>Color
        </div>
        <p class="mt-3 text-sm text-[var(--color-ink-muted)] leading-relaxed">
          Evidence-based product analysis focused on safety and efficacy for Black skin and hair.
        </p>
      </div>
      {
        footer.columns.map((col) => (
          <div>
            <h3 class="text-xs uppercase tracking-wider text-[var(--color-ink-muted)] mb-3">{col.title}</h3>
            <ul class="space-y-2 text-sm">
              {col.links.map((l) => (
                <li>
                  <a href={l.href} class="hover:text-[var(--color-brand)] transition-colors">{l.label}</a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
    <div class="border-t border-[var(--color-pill-bg)] mt-10 pt-6 flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
      <p class="text-xs text-[var(--color-ink-muted)]">{footer.copyright}</p>
      <a href="/privacy-policy/" class="text-xs text-[var(--color-ink-muted)] hover:text-[var(--color-brand)]">Privacy Policy</a>
    </div>
  </div>
</footer>
