---
interface Props {
  label: string;
  href?: string;
}
const { label, href } = Astro.props;
const Tag = href ? 'a' : 'span';
---
<Tag
  {...(href ? { href } : {})}
  class="inline-block px-3 py-1 rounded-full text-xs font-medium bg-[var(--color-pill-bg)] text-[var(--color-brand-deep)] tracking-wide"
>
  {label}
</Tag>
